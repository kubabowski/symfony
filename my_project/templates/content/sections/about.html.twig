{% set slides = [
    { image: section.image1, header: section.text2, text: section.text3 },
    { image: section.image2, header: section.text4, text: section.text5 },
    { image: section.image3, header: section.text6, text: null },
    { image: section.image4, header: null, text: null },
]|filter(s => s.image or s.header or s.text) %}

<section class="about-section">
    <div class="container">
        {% if section.text1 %}
            <div class="section-header">
                <p class="section-subtitle">{{ section.text1 }}</p>
            </div>
        {% endif %}

        {% if slides|length > 0 %}
            <div class="swiper about-swiper" data-controller="swiper">
                <div class="swiper-wrapper">
                    {% for slide in slides %}
                        <article class="swiper-slide">
                            <div class="slide-content">
                                {% if slide.image %}
                                    <img src="/uploads/content/{{ slide.image }}" alt="{{ slide.header }}">
                                {% endif %}
                                <div class="slide-text">
                                    {% if slide.header %}<h3>{{ slide.header }}</h3>{% endif %}
                                    {% if slide.text %}<p>{{ slide.text }}</p>{% endif %}
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
                <div class="swiper-button-prev"></div>
                <div class="swiper-button-next"></div>
                <div class="swiper-pagination"></div>
            </div>
        {% endif %}
    </div>
</section>