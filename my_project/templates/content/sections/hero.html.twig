<section class="hero" style="{% if section.image1 %}background-image:url('/uploads/content/{{ section.image1 }}');{% endif %}">
    <div class="hero-overlay"></div>
    <div class="container">
        <div class="hero-content reveal">
            {% if section.image2 %}
                <img src="/uploads/content/{{ section.image2 }}" class="hero-logo" alt="{{ section.text1 ?? section.title }}">
            {% endif %}

            <h1 class="hero-title">{{ section.text1 ?? section.title }}</h1>

            {% if section.text2 %}
                <p class="hero-tagline">{{ section.text2 }}</p>
            {% endif %}

            {% if section.btnText1 and section.btnLink1 %}
                <a href="{{ section.btnLink1 }}" class="btn btn-primary" style="display:inline-block;margin-top:2rem;">
                    {{ section.btnText1 }}
                </a>
            {% endif %}
        </div>
    </div>
</section>