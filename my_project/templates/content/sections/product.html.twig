<section class="product-section">
    <div class="container">
        <div class="product-grid">
            {% if section.image1 %}
                <img src="/uploads/content/{{ section.image1 }}" alt="{{ section.text1 ?? section.title }}">
            {% endif %}

            <div class="product-content">
                <h2>{{ section.text1 ?? section.title }}</h2>
                {% if section.text2 %}<p>{{ section.text2 }}</p>{% endif %}
                {% if section.text3 %}<p>{{ section.text3 }}</p>{% endif %}

                {% if section.text4 %}
                    <ul class="product-features">
                        {% for feature in section.text4|split('\n')|filter(f => f|trim is not empty) %}
                            <li class="feature-item">
                                <svg class="feature-icon" viewBox="0 0 20 20" fill="none">
                                    <path d="M4 10l4 4 8-8" stroke="#2d5016" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                {{ feature|trim }}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}

                {% if section.btnText1 and section.btnLink1 %}
                    <a href="{{ section.btnLink1 }}" class="btn btn-primary" style="margin-top:2rem;display:inline-block;">
                        {{ section.btnText1 }}
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</section>