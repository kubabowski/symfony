{% extends 'base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block body %}
    <div style="max-width:380px;margin:100px auto;font-family:sans-serif;">
        <h1>Log in</h1>

        {% if error %}
            <p style="color:#b3261e;">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
        {% endif %}

        <form method="post">
            <div style="margin-bottom:1rem;">
                <label for="username">Username</label><br>
                <input type="text" id="username" name="_username" value="{{ last_username }}" autofocus>
            </div>

            <div style="margin-bottom:1rem;">
                <label for="password">Password</label><br>
                <input type="password" id="password" name="_password">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit">Sign in</button>
        </form>
    </div>
{% endblock %}